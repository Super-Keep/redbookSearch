FROM public.ecr.aws/ubuntu/ubuntu:22.04

# 设置工作目录
WORKDIR /app

# 使用 bash
SHELL ["/bin/bash", "-c"]

# 安装 Python + curl
RUN apt-get update && \
    apt-get install -y python3 python3-pip curl ca-certificates gnupg && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# 安装 Node.js 20.x (XHS签名算法需要 >= 20)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# 升级 pip / setuptools
RUN python3 -m pip install --upgrade pip setuptools wheel

# 复制 Python 依赖文件（利用缓存机制）
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# 安装 gunicorn + supervisor
RUN pip3 install --no-cache-dir gunicorn supervisor

# 复制 Node.js 依赖文件（利用缓存机制）
COPY package.json package-lock.json ./
RUN npm install --production

# 复制 static 目录的 Node.js 依赖
COPY static/package.json static/package-lock.json ./static/
RUN cd static && npm install --production

# 复制代码
COPY . .

# 创建日志目录
RUN mkdir -p logs

# 环境变量
ENV PORT=5081
ENV ENV_RUN=TEST

EXPOSE 5081

# 健康检查
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:5081/health || exit 1

# 启动 supervisord
ENTRYPOINT ["supervisord", "-c", "./config/supervisord.conf", "--nodaemon"]
